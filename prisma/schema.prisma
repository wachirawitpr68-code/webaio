generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Researcher {
  id             Int      @id @default(autoincrement())
  name           String
  position       String
  imageUrl       String?
  scholarLink    String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NewsPost {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  imageUrl    String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
